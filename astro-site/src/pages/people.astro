---
import Layout from '../layouts/Layout.astro';
import WorldMap from '../components/WorldMap.astro';
import { getCollection } from 'astro:content';
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;

const allPeople = await getCollection('people');

// Optional: sort or group them by role (PI -> Postdoc -> PhD -> MSc -> undergrad)
const pi = allPeople.filter(person => person.data.role.includes("Investigator") || person.data.role.includes("PI"));
const roleHierarchy: Record<string, number> = {
  "Ph.D. Student": 1,
  "M.Sc. Student": 2,
  "Student": 3
};

const labMembers = allPeople
  .filter(person => 
    !person.data.role.includes("Investigator") && 
    !person.data.role.includes("PI") && 
    !person.data.role.includes("Visiting") && 
    !person.data.role.includes("Alumni")
  )
  .sort((a, b) => {
    const roleA = roleHierarchy[a.data.role] || 4;
    const roleB = roleHierarchy[b.data.role] || 4;
    if (roleA !== roleB) {
      return roleA - roleB;
    }
    return a.data.name.localeCompare(b.data.name);
  });
const visitors = allPeople.filter(person => person.data.role.includes("Visiting"));
const alumni = allPeople.filter(person => person.data.role.includes("Alumni"));
---

<Layout
  title="People"
  description="ChemAI Lab team and collaborators at McMaster University: students, postdocs, and visitors working with Rodrigo Vargas-Hernández on AI for quantum chemistry and materials."
>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32 flex max-w-7xl flex-col">
    
    <div class="mb-16">
      <h1 class="text-4xl md:text-5xl font-heading font-semibold text-primary mb-4 tracking-tight">Our Team</h1>
      <p class="text-lg text-muted-foreground font-light max-w-2xl">
        A diverse group of researchers integrating machine learning with computational chemistry.
      </p>
    </div>

    <!-- Principal Investigator & World Map -->
    <section class="mb-20">
      <h2 class="text-2xl font-heading font-semibold text-foreground mb-8 pb-2 border-b border-border/50">Principal Investigator</h2>
      
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- PI Card -->
        <div class="lg:col-span-1 border-r-0 lg:border-r border-border/40 lg:pr-6 pb-6 lg:pb-0 h-full">
          {pi.map(person => (
            <div class="glass-panel p-6 rounded-2xl border border-border/60 hover-lift h-full flex flex-col items-center justify-center">
              <div class="aspect-square w-36 h-36 rounded-full overflow-hidden mx-auto mb-6 bg-muted shadow-inner relative">
                {person.data.image ? (
                  <img src={`${base}${person.data.image}`} alt={person.data.name} class="w-full h-full object-cover transition-transform duration-500 hover:scale-105" loading="lazy" />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-muted-foreground bg-muted/30">
                    <svg class="w-12 h-12" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"></path></svg>
                  </div>
                )}
              </div>
              <div class="text-center space-y-1">
                <h3 class="font-heading font-semibold text-xl text-foreground">{person.data.name}</h3>
                <p class="text-xs font-semibold uppercase tracking-wider text-accent">{person.data.role}</p>
                {person.data.email && (
                  <a href={`mailto:${person.data.email}`} class="block text-sm text-muted-foreground hover:text-primary transition-colors pt-3">
                    {person.data.email}
                  </a>
                )}
                
                <div class="flex flex-wrap justify-center gap-4 pt-5">
                  {person.data.links?.map(link => (
                    <a href={link.url} target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-primary hover:text-primary-light transition-colors">
                      {link.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
        
        <!-- Interactive D3 Map Island -->
        <div class="lg:col-span-2 flex flex-col justify-center h-full animate-initial fade-in slide-up" style="animation-delay: 200ms;">
          <WorldMap class="w-full h-[400px] lg:h-full min-h-[350px]" />
          <div class="flex items-center justify-center gap-2 mt-4 text-xs font-light text-muted-foreground hidden sm:flex">
            <span class="w-2 h-2 rounded-full bg-[#22d3ee] shadow-[0_0_6px_rgba(34,211,238,0.8)]"></span>
            <p>Highlighting the global footprint of our lab members, collaborators, and alumni.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Lab Members -->
    <section>
      <h2 class="text-2xl font-heading font-semibold text-foreground mb-8 pb-2 border-b border-border/50">Lab Members & Students</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {labMembers.map(person => (
           <div class="glass-panel p-6 rounded-2xl border border-border/60 hover-lift group">
            <div class="aspect-square w-24 h-24 rounded-full overflow-hidden mx-auto mb-4 bg-muted shadow-inner relative">
              {person.data.image ? (
                <img src={`${base}${person.data.image}`} alt={person.data.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-muted-foreground bg-muted/30">
                  <svg class="w-10 h-10" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"></path></svg>
                </div>
              )}
            </div>
            <div class="text-center space-y-1">
              <h3 class="font-heading font-medium text-base text-foreground">{person.data.name}</h3>
              <p class="text-[10px] font-semibold uppercase tracking-wider text-accent">{person.data.role}</p>
              
              <div class="flex flex-wrap justify-center gap-3 pt-3">
                {person.data.links?.map(link => (
                  <a href={link.url} target="_blank" rel="noopener noreferrer" class="text-[11px] font-medium text-primary hover:text-primary-light transition-colors">
                    {link.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    {visitors.length > 0 && (
      <section class="mt-20">
        <h2 class="text-2xl font-heading font-semibold text-foreground mb-8 pb-2 border-b border-border/50">Visitors & Collaborators</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {visitors.map(person => (
             <div class="glass-panel p-6 rounded-2xl border border-border/60 hover-lift group">
              <div class="aspect-square w-24 h-24 rounded-full overflow-hidden mx-auto mb-4 bg-muted shadow-inner relative">
                {person.data.image ? (
                  <img src={`${base}${person.data.image}`} alt={person.data.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-muted-foreground bg-muted/30">
                    <svg class="w-10 h-10" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"></path></svg>
                  </div>
                )}
              </div>
              <div class="text-center space-y-1">
                <h3 class="font-heading font-medium text-base text-foreground">{person.data.name}</h3>
                <p class="text-[10px] font-semibold uppercase tracking-wider text-accent">{person.data.role}</p>
                <div class="flex flex-wrap justify-center gap-3 pt-3">
                  {person.data.links?.map(link => (
                    <a href={link.url} target="_blank" rel="noopener noreferrer" class="text-[11px] font-medium text-primary hover:text-primary-light transition-colors">
                      {link.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    {alumni.length > 0 && (
      <section class="mt-20">
        <h2 class="text-2xl font-heading font-semibold text-foreground mb-8 pb-2 border-b border-border/50">Alumni</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
          {alumni.map(person => (
             <div class="glass-panel p-6 rounded-2xl border border-border/60 hover-lift group grayscale opacity-80 hover:grayscale-0 hover:opacity-100 transition-all duration-300">
              <div class="aspect-square w-24 h-24 rounded-full overflow-hidden mx-auto mb-4 bg-muted shadow-inner relative">
                {person.data.image ? (
                  <img src={`${base}${person.data.image}`} alt={person.data.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-muted-foreground bg-muted/30">
                    <svg class="w-10 h-10" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"></path></svg>
                  </div>
                )}
              </div>
              <div class="text-center space-y-1">
                <h3 class="font-heading font-medium text-base text-foreground">{person.data.name}</h3>
                <p class="text-[10px] font-semibold uppercase tracking-wider text-muted-foreground">Alumni</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

  </div>
</Layout>
