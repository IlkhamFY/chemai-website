---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase.slice(0, -1) : rawBase;

const allPublications = await getCollection('publications');
const sortedPublications = allPublications.sort((a, b) => b.data.year - a.data.year);
---

<Layout title="Publications" description="Publications and research output from the ChemAI Lab.">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32 flex max-w-7xl flex-col">
    
    <div class="mb-16">
      <h1 class="text-4xl md:text-5xl font-heading font-semibold text-primary mb-4 tracking-tight">Publications</h1>
      <p class="text-lg text-muted-foreground font-light max-w-2xl">
        Recent research output, papers, and preprints from our group.
      </p>
    </div>

    <div class="space-y-12">
      {sortedPublications.map(pub => (
        <article class="flex flex-col md:flex-row gap-8 items-start group relative">
          
          <!-- Image Section -->
          <div class="w-full md:w-1/3 lg:w-1/4 shrink-0 rounded-xl overflow-hidden glass-panel border border-border/60 aspect-[4/3] bg-background">
            {pub.data.thumbnail ? (
              <img src={`${base}${pub.data.thumbnail}`} alt={`Thumbnail for ${pub.data.title}`} class="w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            ) : (
              <div class="w-full h-full flex items-center justify-center text-muted-foreground bg-muted/30 p-4 font-mono text-xs text-center border-b border-border">
                [No Image]
              </div>
            )}
          </div>

          <!-- Content Section -->
          <div class="flex-1 space-y-3 pt-2 md:pt-0">
            <h2 class="text-xl md:text-2xl font-heading font-medium text-foreground tracking-tight leading-snug group-hover:text-primary transition-colors">
              {pub.data.title}
            </h2>
            <p class="text-sm font-medium text-primary-light">
              {pub.data.authors} ({pub.data.year})
            </p>
            <p class="text-sm text-muted-foreground leading-relaxed font-light line-clamp-4">
              {pub.data.abstract}
            </p>

            <div class="flex flex-wrap gap-3 pt-4">
              {pub.data.links?.map(link => (
                <a 
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center px-4 py-1.5 border border-primary/20 text-xs font-medium rounded-full text-primary hover:bg-primary hover:text-white transition-all shadow-sm"
                >
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</Layout>
